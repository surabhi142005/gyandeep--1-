{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS_BUILDER",
    "buildPack": "nodejs"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyLimit": 5,
    "runtime": "node",
    "startCommand": "node server/index.js",
    "environment": [
      {
        "key": "NODE_ENV",
        "value": "production"
      }
    ]
  }
}