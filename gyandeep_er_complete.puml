@startuml Gyandeep_Full_ER_Diagram

' ============================================================
' Gyandeep Complete ER Diagram
' All Entities, Attributes, and Relationships
' ============================================================

hide stereotypes
skinparam linetype ortho
skinparam entity {
    BackgroundColor White
    BorderColor #2C3E50
    ArrowColor #2C3E50
}
skinparam attribute {
    BackgroundColor #ECF0F1
    BorderColor #3498DB
    FontColor #2C3E50
}

' ============================================================
' ENTITY: USERS (Base - stores all user types)
' ============================================================
entity "USERS\n(Base Entity)" as users {
    *id : UUID <<PK>>
    --
    *email : TEXT <<UK>>
    *name : TEXT
    password_hash : TEXT
    *role : TEXT <<ENUM: admin|teacher|student>>
    google_id : TEXT <<UK>>
    face_vector : VECTOR(128)
    email_verified : BOOLEAN
    xp : INT
    coins : INT
    preferences : JSONB
    created_at : TIMESTAMPTZ
    updated_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: SUBJECTS
' ============================================================
entity "SUBJECTS" as subjects {
    *id : UUID <<PK>>
    --
    *name : TEXT <<UK>>
    description : TEXT
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: CLASSES
' ============================================================
entity "CLASSES" as classes {
    *id : UUID <<PK>>
    --
    *name : TEXT
    description : TEXT
    teacher_id : UUID <<FK>>
    subject_id : UUID <<FK>>
    created_at : TIMESTAMPTZ
    updated_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: CLASS_ENROLLMENTS (N:M)
' ============================================================
entity "CLASS_ENROLLMENTS\n(Enrollment)" as enrollments {
    *class_id : UUID <<PK>> <<FK>>
    *student_id : UUID <<PK>> <<FK>>
    --
    enrolled_at : TIMESTAMPTZ
    status : TEXT
}

' ============================================================
' ENTITY: CLASS_SESSIONS
' ============================================================
entity "CLASS_SESSIONS\n(Active Session)" as sessions {
    *id : UUID <<PK>>
    --
    *class_id : UUID <<FK>>
    subject_id : UUID <<FK>>
    teacher_id : UUID <<FK>>
    *code : CHAR(6) <<UK>>
    *expiry : TIMESTAMPTZ
    location_lat : DECIMAL
    location_lng : DECIMAL
    radius_m : INT
    notes_url : TEXT
    notes_hash : TEXT
    quiz_published : BOOLEAN
    is_active : BOOLEAN
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: ATTENDANCE
' ============================================================
entity "ATTENDANCE" as attendance {
    *id : BIGSERIAL <<PK>>
    --
    *session_id : UUID <<FK>>
    *student_id : UUID <<FK>>
    *status : TEXT <<ENUM: present|absent|late|excused>>
    geo_location_lat : DECIMAL
    geo_location_lng : DECIMAL
    face_verified : BOOLEAN
    verified_at : TIMESTAMPTZ
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: QUIZZES
' ============================================================
entity "QUIZZES" as quizzes {
    *id : UUID <<PK>>
    --
    *session_id : UUID <<FK>>
    *title : TEXT
    *questions : JSONB
    time_limit : INT
    passing_score : DECIMAL
    created_by : UUID <<FK>>
    created_at : TIMESTAMPTZ
    published_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: QUIZ_ATTEMPTS
' ============================================================
entity "QUIZ_ATTEMPTS" as quiz_attempts {
    *id : UUID <<PK>>
    --
    *quiz_id : UUID <<FK>>
    *student_id : UUID <<FK>>
    *answers : JSONB
    *score : DECIMAL
    max_score : DECIMAL
    started_at : TIMESTAMPTZ
    submitted_at : TIMESTAMPTZ
    time_taken : INT
}

' ============================================================
' ENTITY: PERFORMANCE
' ============================================================
entity "PERFORMANCE" as performance {
    *id : BIGSERIAL <<PK>>
    --
    *student_id : UUID <<FK>>
    subject_id : UUID <<FK>>
    session_id : UUID <<FK>>
    quiz_id : UUID <<FK>>
    *score : DECIMAL
    max_score : DECIMAL
    percentage : DECIMAL
    *recorded_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: GRADES
' ============================================================
entity "GRADES\n(Gradebook)" as grades {
    *id : UUID <<PK>>
    --
    *student_id : UUID <<FK>>
    teacher_id : UUID <<FK>>
    *subject : TEXT
    *category : TEXT
    *title : TEXT
    *score : DECIMAL
    *max_score : DECIMAL
    weight : DECIMAL
    *date : DATE
    description : TEXT
    created_at : TIMESTAMPTZ
    updated_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: QUESTION_BANK
' ============================================================
entity "QUESTION_BANK" as question_bank {
    *id : UUID <<PK>>
    --
    *question : TEXT
    *options : JSONB
    *correct_answer : TEXT
    subject : TEXT
    topic : TEXT
    tags : JSONB
    difficulty : TEXT <<ENUM: easy|medium|hard>>
    explanation : TEXT
    notes_hash : TEXT
    created_by : UUID <<FK>>
    created_at : TIMESTAMPTZ
    updated_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: NOTES
' ============================================================
entity "NOTES\n(Study Materials)" as notes {
    *id : UUID <<PK>>
    --
    *title : TEXT
    *content : TEXT
    subject : TEXT
    topic : TEXT
    file_url : TEXT
    file_type : TEXT
    file_size : INT
    uploaded_by : UUID <<FK>>
    class_id : UUID <<FK>>
    is_public : BOOLEAN
    views : INT
    created_at : TIMESTAMPTZ
    updated_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: TIMETABLE
' ============================================================
entity "TIMETABLE" as timetable {
    *id : UUID <<PK>>
    --
    *class_id : UUID <<FK>>
    subject_id : UUID <<FK>>
    teacher_id : UUID <<FK>>
    *day_of_week : TEXT
    *start_time : TIME
    *end_time : TIME
    room : TEXT
    is_active : BOOLEAN
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: BADGES
' ============================================================
entity "BADGES" as badges {
    *id : SERIAL <<PK>>
    --
    *name : TEXT <<UK>>
    *slug : TEXT <<UK>>
    description : TEXT
    icon : TEXT
    xp_value : INT
    coin_value : INT
    criteria : JSONB
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: USER_BADGES
' ============================================================
entity "USER_BADGES" as user_badges {
    *user_id : UUID <<PK>> <<FK>>
    *badge_id : INT <<PK>> <<FK>>
    --
    awarded_at : TIMESTAMPTZ
    awarded_by : UUID <<FK>>
}

' ============================================================
' ENTITY: ANNOUNCEMENTS
' ============================================================
entity "ANNOUNCEMENTS" as announcements {
    *id : UUID <<PK>>
    --
    *title : TEXT
    *content : TEXT
    class_id : UUID <<FK>>
    posted_by : UUID <<FK>>
    priority : TEXT <<ENUM: low|normal|high|urgent>>
    is_pinned : BOOLEAN
    expires_at : TIMESTAMPTZ
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: NOTIFICATIONS
' ============================================================
entity "NOTIFICATIONS" as notifications {
    *id : UUID <<PK>>
    --
    *user_id : UUID <<FK>>
    *title : TEXT
    *message : TEXT
    *type : TEXT <<ENUM: info|warning|error|success>>
    *read : BOOLEAN
    action_url : TEXT
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: AUDIT_LOGS
' ============================================================
entity "AUDIT_LOGS" as audit_logs {
    *id : BIGSERIAL <<PK>>
    --
    *user_id : UUID <<FK>>
    *action : TEXT
    entity_type : TEXT
    entity_id : UUID
    details : JSONB
    ip_address : TEXT
    user_agent : TEXT
    *created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: OTP_CODES
' ============================================================
entity "OTP_CODES" as otp_codes {
    *id : UUID <<PK>>
    --
    *user_id : UUID <<FK>>
    *code : TEXT
    *purpose : TEXT <<ENUM: login|reset|verify|change_email>>
    *expires_at : TIMESTAMPTZ
    used_at : TIMESTAMPTZ
    attempts : INT
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: TICKETS (Support)
' ============================================================
entity "TICKETS" as tickets {
    *id : UUID <<PK>>
    --
    *user_id : UUID <<FK>>
    *subject : TEXT
    *description : TEXT
    *status : TEXT <<ENUM: open|in_progress|resolved|closed>>
    priority : TEXT <<ENUM: low|medium|high|critical>>
    category : TEXT
    assigned_to : UUID <<FK>>
    resolved_at : TIMESTAMPTZ
    created_at : TIMESTAMPTZ
    updated_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: TICKET_RESPONSES
' ============================================================
entity "TICKET_RESPONSES" as ticket_responses {
    *id : UUID <<PK>>
    --
    *ticket_id : UUID <<FK>>
    *user_id : UUID <<FK>>
    *message : TEXT
    is_internal : BOOLEAN
    created_at : TIMESTAMPTZ
}

' ============================================================
' ENTITY: ANALYTICS
' ============================================================
entity "ANALYTICS" as analytics {
    *id : UUID <<PK>>
    --
    *user_id : UUID <<FK>>
    *event_type : TEXT
    event_data : JSONB
    session_id : UUID <<FK>>
    created_at : TIMESTAMPTZ
}

' ============================================================
' RELATIONSHIPS - ALL CONNECTIONS
' ============================================================

' ---- USER RELATIONSHIPS ----

' Users creates/updates Classes (Teacher -> Class)
users ||--o{ classes : "1 teaches N"

' Users enrolls in Classes (Student -> Class via Enrollment)
users ||--o{ enrollments : "N enrolled_in"
classes ||--o{ enrollments : "N has_enrolled"

' Users creates Class Sessions (Teacher -> Session)
users ||--o{ sessions : "1 conducts N"

' Users marks Attendance (Student -> Attendance)
users ||--o{ attendance : "N marks"

' Users achieves Performance (Student -> Performance)
users ||--o{ performance : "N achieves"

' Users receives Grades (Student <- Grades)
users ||--o{ grades : "N receives"

' Users assigns Grades (Teacher -> Grades)
users ||--o{ grades : "1 assigns N"

' Users creates Quizzes (Teacher -> Quiz)
users ||--o{ quizzes : "1 creates N"

' Users attempts Quizzes (Student -> Quiz Attempts)
users ||--o{ quiz_attempts : "N attempts"

' Users creates Questions (Teacher -> Question Bank)
users ||--o{ question_bank : "1 creates N"

' Users uploads Notes (Teacher/Student -> Notes)
users ||--o{ notes : "N uploads"

' Users creates Timetable entries (Teacher -> Timetable)
users ||--o{ timetable : "1 manages N"

' Users earns Badges (Student -> User Badges)
users ||--o{ user_badges : "N earns"

' Users posts Announcements (Teacher -> Announcements)
users ||--o{ announcements : "1 posts N"

' Users receives Notifications (All -> Notifications)
users ||--o{ notifications : "N receives"

' Users triggers Audit Logs (All -> Audit Logs)
users ||--o{ audit_logs : "N performs"

' Users owns OTP Codes (All -> OTP Codes)
users ||--o{ otp_codes : "N uses"

' Users creates Tickets (Student -> Tickets)
users ||--o{ tickets : "N creates"

' Users responds to Tickets (All -> Ticket Responses)
users ||--o{ ticket_responses : "N responds"

' Users triggers Analytics (All -> Analytics)
users ||--o{ analytics : "N generates"

' ---- SUBJECT RELATIONSHIPS ----

' Subjects belong to Classes
subjects ||--o{ classes : "1 has N"

' Subjects assigned to Sessions
subjects ||--o{ sessions : "1 used_in N"

' Subjects tracked in Performance
subjects ||--o{ performance : "1 tracked_in N"

' Subjects in Question Bank
subjects ||--o{ question_bank : "1 categorized_in N"

' Subjects in Timetable
subjects ||--o{ timetable : "1 scheduled_for N"

' Subjects in Notes
subjects ||--o{ notes : "1 has N"

' ---- CLASS RELATIONSHIPS ----

' Classes have Sessions
classes ||--o{ sessions : "1 conducts N"

' Classes have Enrollments
classes ||--o{ enrollments : "1 has N"

' Classes have Notes
classes ||--o{ notes : "1 contains N"

' Classes have Timetable
classes ||--o{ timetable : "1 has N"

' Classes have Announcements
classes ||--o{ announcements : "1 has N"

' ---- SESSION RELATIONSHIPS ----

' Sessions record Attendance
sessions ||--o{ attendance : "1 records N"

' Sessions have Quizzes
sessions ||--o{ quizzes : "1 generates N"

' Sessions track Performance
sessions ||--o{ performance : "1 measures N"

' Sessions generate Question Bank
sessions ||--o{ question_bank : "1 sources N"

' Sessions in Analytics
sessions ||--o{ analytics : "1 tracked_in N"

' ---- QUIZ RELATIONSHIPS ----

' Quizzes have Attempts
quizzes ||--o{ quiz_attempts : "1 has N"

' Quizzes track Performance
quizzes ||--o{ performance : "1 measures N"

' ---- BADGE RELATIONSHIPS ----

' Badges awarded to Users
badges ||--o{ user_badges : "1 awarded_to N"

' ---- TICKET RELATIONSHIPS ----

' Tickets assigned to Users
users ||--o{ tickets : "N assigned_to"

' Tickets have Responses
tickets ||--o{ ticket_responses : "1 has N"

@enduml
