# Gyandeep Environment Configuration
# Copy to .env.local and fill in your values

# ─── SUPABASE (Required) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-side only — Vercel env vars, NOT in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── GOOGLE GEMINI AI (Required for quiz/chat) ────────────────────────────────
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── FRONTEND CONFIGURATION ───────────────────────────────────────────────────
# Base URL for API calls (leave blank for same-origin / Vercel deployment)
VITE_API_URL=

# ─── ALCHEMY (Blockchain RPC) ─────────────────────────────────────────────────
VITE_ALCHEMY_API_KEY=your-alchemy-api-key
ALCHEMY_API_KEY=your-alchemy-api-key

# ─── EMAIL (Resend — for custom notifications) ────────────────────────────────
RESEND_API_KEY=your-resend-api-key

# ─── GOOGLE OAUTH (Optional — configured in Supabase dashboard) ───────────────
# GOOGLE_CLIENT_ID=your_client_id
# GOOGLE_CLIENT_SECRET=your_client_secret

# ─── BLOCKCHAIN DEPLOYMENT ────────────────────────────────────────────────────
# Wallet private key for Hardhat deployments (NEVER commit this)
# PRIVATE_KEY=your-wallet-private-key

# ─── SERVER (Required) ────────────────────────────────────────────────────────
# BOTH are required — server will refuse to start if either is missing
JWT_SECRET=replace-with-strong-jwt-secret-min-32-chars
SESSION_SECRET=replace-with-strong-session-secret-min-32-chars

# ─── SERVER (Optional) ────────────────────────────────────────────────────────
# PORT=3001
# WEBSOCKET_PORT=3002

# ─── PYTHON MICROSERVICE ──────────────────────────────────────────────────────
# URL of the Python face/location service
PYTHON_SERVICE_URL=http://localhost:5001
# Shared secret between Express and the Python service (prevents direct :5001 access)
INTERNAL_SERVICE_SECRET=replace-with-strong-internal-secret

# ─── EMAIL ────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here
# SMTP_FROM=noreply@gyandeep.com
