# ============================================================
# GYANDEEP - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ============================================================

# ------------------------------------------------------------
# REQUIRED: Core Application Settings
# ------------------------------------------------------------

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gyandeep?retryWrites=true&w=majority
MONGODB_URI=

# JWT secrets (generate strong random strings)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Server port (default: 3001)
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# ------------------------------------------------------------
# REQUIRED: CORS Configuration
# ------------------------------------------------------------

# Comma-separated list of allowed origins for CORS
# Development: http://localhost:5173,http://localhost:3000
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------
# OPTIONAL: AI Features (Google Gemini)
# ------------------------------------------------------------

# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ------------------------------------------------------------
# OPTIONAL: Email Service (Resend)
# ------------------------------------------------------------

# Get your API key from: https://resend.com
RESEND_API_KEY=
# From email address for sending emails
RESEND_FROM_EMAIL=noreply@gyandeep.edu
# Admin email for notifications
ADMIN_EMAIL=admin@gyandeep.edu

# ------------------------------------------------------------
# OPTIONAL: Cloud Storage (Cloudflare R2 / AWS S3)
# ------------------------------------------------------------

# If not configured, files will be stored as base64 in database

# Cloudflare R2 / S3 credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=gyandeep-storage
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# AWS S3 alternative (uncomment if using S3 instead of R2)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=

# ------------------------------------------------------------
# OPTIONAL: Google OAuth
# ------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------
# OPTIONAL: External Services
# ------------------------------------------------------------

# Python Face Recognition Service URL (if deployed separately)
FACE_RECOGNITION_SERVICE_URL=http://localhost:5000

# ------------------------------------------------------------
# OPTIONAL: Security & Rate Limiting
# ------------------------------------------------------------

# CSRF Token (generate random string)
CSRF_SECRET=

# Rate limiting window in minutes
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------
# OPTIONAL: Redis Cache & Session Store
# ------------------------------------------------------------

# Redis URL (format: redis://<host>:<port>/<db>)
# If not configured, caching features will be disabled
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# REQUIRED FOR VERCEL DEPLOYMENT: Upstash (Vercel KV/Redis)
# ------------------------------------------------------------

# Get from: https://vercel.com/dash/stores/kv or https://upstash.com
# Upstash Redis REST URL for serverless functions
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel deployment URL will be auto-set
# Add in Vercel Dashboard: Settings > Environment Variables
# Key: ALLOWED_ORIGIN
# Value: Your deployment URL (e.g., https://your-project.vercel.app)

# Log level (error | warn | info | debug)
LOG_LEVEL=info

# ------------------------------------------------------------
# PRODUCTION SPECIFIC SETTINGS
# ------------------------------------------------------------

# Trust proxy (required when behind load balancer/reverse proxy)
# TRUST_PROXY=true

# SSL Certificate paths (if not using reverse proxy)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt

# ------------------------------------------------------------
# DEVELOPMENT SETTINGS
# ------------------------------------------------------------

# Enable request logging in development
DEBUG=true
