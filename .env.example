# Gyandeep Environment Configuration

# --- CORE SERVICES ---

# Google Gemini AI API Key (required for AI and Chatbot features)
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (default is 3000)
PORT=3000

# Node Environment (development | production)
NODE_ENV=production

# WebSocket server port (if using separate websocket service)
WEBSOCKET_PORT=3002

# Session and JWT secrets (set strong values in production)
SESSION_SECRET=replace-with-strong-session-secret
JWT_SECRET=replace-with-strong-jwt-secret
# --- EMAIL SERVICE (SMTP) ---
# Required for OTP multi-factor authentication and password resets
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
# For Gmail, use an "App Password" (https://myaccount.google.com/apppasswords)
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@gyandeep.com

# --- FRONTEND CONFIGURATION ---
# Base URL for the API (leave blank in production if serving from the same domain)
VITE_API_URL=

# --- OPTIONAL INTEGRATIONS ---

# Google OAuth 2.0 (optional - for backend integration)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret

# --- BLOCKCHAIN CONFIGURATION (EXPERIMENTAL) ---
# If using a custom RPC provider (e.g. Infura, Alchemy)
# VITE_RPC_URL=https://mainnet.infura.io/v3/your_project_id
