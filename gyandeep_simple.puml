@startuml
skinparam activityBackgroundColor #FEFEFE
skinparam activityBorderColor #222222
skinparam activityStartColor #00AA00
skinparam activityEndColor #AA0000
skinparam arrowColor #222222
skinparam maxMessageSize 200

title Gyandeep Activity Diagram

|Student|
start
:Open App;
:Login (Email/Face ID);
:View Dashboard;

if (Join Class) then
  :Enter Code;
  :Verify Location;
  :Mark Attendance;
endif

if (Take Quiz) then
  :Answer Questions;
  :Submit;
  :View Score;
endif

if (View Grades) then
  :View Performance;
  :View Analytics;
endif

if (Get Certificate) then
  :Download NFT;
endif

:Logout;
stop

|Teacher|
start
:Login;
:Create Session;
:Generate Code;
:Take Attendance;
:Upload Notes;
:Create Quiz;
:Grade Students;
:View Analytics;
:Logout;
stop

|Admin|
start
:Login;
:Manage Users;
:Manage Subjects;
:Manage Classes;
:View Analytics;
:Manage Question Bank;
:Logout;
stop

@enduml
