@startuml
skinparam activityBackgroundColor #FFFFFF
skinparam activityBorderColor #333333
skinparam activityStartColor #4CAF50
skinparam activityEndColor #F44336
skinparam arrowColor #333333

title Gyandeep - Student Workflow

|Student|
start
:Login to Gyandeep;
:View Dashboard;

:Select Class Session;
:Enter Session Code;
:App Verifies Location;

if (Within Radius?) then (Yes)
  :Mark Attendance as Present;
  :Save to Database;
  :Record to Blockchain;
else (No)
  :Show Error;
  :Cannot Mark Attendance;
endif

:View Notes;
:Take Quiz;
:Answer Questions;
:Submit Quiz;
:View Score;

if (Score Good?) then (Yes)
  :Save Grade;
  :Update Performance;
else (No)
  :Retry Quiz;
endif

:View Analytics;
:Download Certificate;
stop

@enduml
