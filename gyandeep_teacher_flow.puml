@startuml
skinparam activityBackgroundColor #FFFFFF
skinparam activityBorderColor #333333
skinparam activityStartColor #4CAF50
skinparam activityEndColor #F44336
skinparam arrowColor #333333

title Gyandeep - Teacher Workflow

|Teacher|
start
:Login to Gyandeep;
:View Teacher Dashboard;

:Select Option;

if (Start Session) then
  :Create New Session;
  :Select Subject;
  :Set Attendance Radius;
  :Generate Session Code;
  :Start Session;
endif

if (Take Attendance) then
  :View Student List;
  :Verify Student Locations;
  :Mark Present/Absent;
  :Save Attendance;
  :Record to Blockchain;
endif

if (Upload Notes) then
  :Select File;
  :Upload to Server;
  :Share with Students;
endif

if (Create Quiz) then
  :Add Questions;
  :Set Correct Answers;
  :Publish Quiz;
endif

if (Grade Students) then
  :View Quiz Submissions;
  :Assign Grades;
  :Save Grades;
  :Record to Blockchain;
endif

if (View Analytics) then
  :View Class Performance;
  :View Student Progress;
  :Generate Reports;
endif

:Logout;
stop

@enduml
