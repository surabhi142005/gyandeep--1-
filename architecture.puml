@startuml Gyandeep Architecture

!theme plain

skinparam componentStyle uml2

package "Layer 1: Presentation" {
    [React 18]
    [TypeScript]
    [Vite]
    [Tailwind CSS]
    [Recharts]
    [face-api.js]
}

package "Layer 2: Business Logic" {
    [Node.js]
    [Express.js]
    [JWT Auth]
    [RBAC]
    [SSE]
    [WebSocket]
}

package "Layer 3: Data" {
    database "SQLite" {
        [users]
        [grades]
        [attendance]
        [timetable]
        [question_bank]
        [tickets]
        [notes]
        [audit_logs]
    }
    folder "File Storage" {
        [images]
        [documents]
        [face_data]
    }
}

[React 18] --> [Express.js]
[TypeScript] --> [Express.js]
[Vite] --> [Express.js]
[Tailwind CSS] --> [Express.js]
[Recharts] --> [Express.js]
[face-api.js] --> [Express.js]

[Express.js] --> [JWT Auth]
[Express.js] --> [RBAC]
[Express.js] --> [SSE]
[Express.js] --> [WebSocket]

[JWT Auth] --> [SQLite]
[RBAC] --> [SQLite]

[SQLite] --> [users]
[SQLite] --> [grades]
[SQLite] --> [attendance]
[SQLite] --> [timetable]
[SQLite] --> [question_bank]
[SQLite] --> [tickets]
[SQLite] --> [notes]
[SQLite] --> [audit_logs]

[Express.js] --> [images]
[Express.js] --> [documents]
[Express.js] --> [face_data]

@enduml
