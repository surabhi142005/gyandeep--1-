@startuml
skinparam activityBackgroundColor #F0F0F0
skinparam activityBorderColor #333333
skinparam activityStartColor #4CAF50
skinparam activityEndColor #F44336
skinparam arrowColor #333333

title Gyandeep Activity Diagram

|Student|
start
:Open Gyandeep App;
:Login (Email/Password or Face ID);

if (Login Successful?) then (Yes)
  :Show Dashboard;
else (No)
  :Show Error;
  :Try Login Again;
  stop
endif

|Student|
repeat
  :Select Menu Option;
  
  if (View Classes) then
    :View Class List;
    :Select Class;
    :View Class Details;
  endif
  
  if (Join Session) then
    :Enter Session Code;
    :Verify Location;
    :Mark Attendance;
  endif
  
  if (Take Quiz) then
    :View Quiz Questions;
    :Select Answers;
    :Submit Quiz;
    :View Score;
    :Save Grade;
  endif
  
  if (View Grades) then
    :View Performance;
    :View Analytics;
  endif
  
  if (Download Certificate) then
    :Request NFT Certificate;
    :Verify on Blockchain;
    :Download Certificate;
  endif
  
repeat while (Continue Using App?)

|Student|
:Logout;
stop

@enduml
