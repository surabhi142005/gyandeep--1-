# ============================================================
# GYANDEEP - Production Environment Variables
# ============================================================
# This file is for PRODUCTION deployment settings
# Copy to your production server and fill in actual values
# ============================================================

# ------------------------------------------------------------
# REQUIRED: Core Application Settings
# ------------------------------------------------------------

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/gyandeep?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/gyandeep?retryWrites=true&w=majority

# JWT secrets - GENERATE NEW ONES FOR PRODUCTION!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_HEX_SECRET

# Server port
PORT=3001

# Set to production
NODE_ENV=production

# ------------------------------------------------------------
# REQUIRED: CORS Configuration
# ------------------------------------------------------------

# Your production domain(s) - IMPORTANT: Change this!
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ------------------------------------------------------------
# RECOMMENDED: AI Features (Google Gemini)
# ------------------------------------------------------------

# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ------------------------------------------------------------
# RECOMMENDED: Email Service (Resend)
# ------------------------------------------------------------

# Get your API key from: https://resend.com
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ------------------------------------------------------------
# OPTIONAL: Cloud Storage (Cloudflare R2 / AWS S3)
# ------------------------------------------------------------

# If not configured, files stored as base64 in database
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=gyandeep-storage
R2_ENDPOINT=https://your_account.r2.cloudflarestorage.com

# ------------------------------------------------------------
# OPTIONAL: Redis Cache
# ------------------------------------------------------------

# Upstash Redis (production)
REDIS_URL=rediss://default:gQAAAAAAARfXAAIncDFhOTBjYjg1MDY3ZWE0NGM2YTFhYTRhOWNiMDc0MmRjZnAxNzE2Mzk@fun-airedale-71639.upstash.io:443

# ------------------------------------------------------------
# SECURITY CHECKLIST
# ------------------------------------------------------------
# [ ] Changed MONGODB_URI password
# [ ] Generated new JWT_SECRET and JWT_REFRESH_SECRET
# [ ] Set ALLOWED_ORIGINS to your production domain only
# [ ] Configured GEMINI_API_KEY (enables AI features)
# [ ] Configured RESEND_API_KEY (enables email)
# [ ] Configured R2 credentials (enables file storage)
# [ ] Configured REDIS_URL (improves caching)
# [ ] Whitelisted your server IP in MongoDB Atlas
# [ ] Enabled SSL/HTTPS on your domain
