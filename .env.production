#!/bin/bash
# .env production template — copy to .env and fill in secrets before running

NODE_ENV=production
PORT=3001
WEBSOCKET_PORT=3002

# Session and JWT secrets (generate strong values with: openssl rand -base64 32)
SESSION_SECRET=your-strong-session-secret-32-chars-min
JWT_SECRET=your-strong-jwt-secret-32-chars-min

# Google Gemini AI (get at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key

# Google OAuth (optional, get at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend API URL (where frontend points to backend)
VITE_API_URL=https://your-domain.com

# Database (SQLite auto-created at ./server/data/gyandeep.db)
DATABASE_URL=sqlite://./server/data/gyandeep.db

# SMTP for email (optional, for password resets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com
